# Environment variables for ad-shark backend
# Copy this to .env and fill in values for your environment

# App
APP_NAME=ad-shark
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:5173","http://localhost:4173"]

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/adshark

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth — CHANGE THESE IN PRODUCTION
JWT_SECRET_KEY=change-me-in-production-use-a-real-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Analytics (optional)
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# Error monitoring (optional)
SENTRY_DSN=

# Storage for share card images (optional)
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=adshark-assets
STORAGE_PUBLIC_URL=
